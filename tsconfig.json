{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"esModuleInterop": true,
		"exactOptionalPropertyTypes": false,
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"noUncheckedIndexedAccess": false,
		"paths": {
			"~shared/*": ["./shared/*"],
			"~utils/*": ["./utils/*"],
		},
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
	},
	"include": [
		"__tests__/**/*.ts",
		"configurations/**/*.ts",
		"shared/**/*.ts",
		"tsdown.config.ts",
		"types/**/*.d.ts",
		"utils/**/*.ts",
		"vitest.config.ts",
	],
}
