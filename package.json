{
	"name": "@morev/stylelint-config",
	"description": "Strict shareable Stylelint configuration",
	"type": "module",
	"private": false,
	"version": "8.0.2",
	"engines": {
		"node": ">=22"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"author": {
		"name": "Maxim Morev",
		"email": "max.seainside@gmail.com"
	},
	"homepage": "https://github.com/MorevM/stylelint-config#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/MorevM/stylelint-config"
	},
	"keywords": [
		"stylelint",
		"stylelintconfig",
		"config",
		"codestyle"
	],
	"files": [
		"build"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./css": {
			"types": "./dist/configurations/css.d.ts",
			"import": "./dist/configurations/css.js"
		},
		"./scss": {
			"types": "./dist/configurations/scss.d.ts",
			"import": "./dist/configurations/scss.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"prepare": "lefthook install",
		"vscode-settings": "cp .vscode/settings.template.json .vscode/settings.json",
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"release": "release-it --disable-metrics"
	},
	"peerDependencies": {
		"stylelint": "^17.0.0"
	},
	"dependencies": {
		"@morev/stylelint-plugin": "^0.5.0",
		"@morev/utils": "^3.15.0",
		"@stylistic/stylelint-plugin": "^5.2.0",
		"postcss": "^8.5.16",
		"postcss-scss": "^4.0.9",
		"stylelint-declaration-block-no-ignored-properties": "^3.0.0",
		"stylelint-high-performance-animation": "^2.0.0",
		"stylelint-no-nested-media": "^0.1.0",
		"stylelint-order": "^8.1.1",
		"stylelint-scss": "^7.1.1",
		"stylelint-selector-tag-no-without-class": "^4.1.0",
		"stylelint-use-nesting": "^6.0.2"
	},
	"devDependencies": {
		"@morev/commitlint-config": "^0.2.2",
		"@morev/eslint-config": "^41.0.0",
		"@release-it/conventional-changelog": "^8.0.2",
		"eslint": "9.39.4",
		"lefthook": "^2.1.9",
		"release-it": "^20.2.1",
		"stylelint": "^17.14.0",
		"stylelint-define-config": "^17.11.0",
		"stylelint-find-new-rules": "^6.0.0",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
